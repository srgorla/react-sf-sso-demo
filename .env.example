VITE_APP_REDIRECT_URI=http://localhost:5173/callback

# Internal (Salesforce My Domain / Okta-enabled org)
VITE_SF_INTERNAL_AUTHORITY=https://<your-my-domain>.my.salesforce.com
VITE_SF_INTERNAL_CLIENT_ID=<internal-connected-app-consumer-key>
VITE_SF_INTERNAL_SCOPE=openid profile email api id
VITE_INTERNAL_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/?mode=internal

# Portal (Experience Cloud)
VITE_SF_PORTAL_CLIENT_ID=<portal-connected-app-consumer-key>
VITE_SF_PORTAL_SCOPE=openid profile email
VITE_SF_PORTAL_OAUTH_INIT_URL=https://my-uat.earlywarning.com/customer/services/oauth2/authorize
VITE_SF_PORTAL_APPEND_STANDARD_PARAMS=true
VITE_SF_PORTAL_TOKEN_URL=https://<your-my-domain>.my.salesforce.com/services/oauth2/token
VITE_SF_PORTAL_LOGOUT_URL=https://my-uat.earlywarning.com/customer/secur/logout.jsp
VITE_PORTAL_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/?mode=portal
